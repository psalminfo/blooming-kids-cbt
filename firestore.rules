rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isStaff() { return isSignedIn() && (request.auth.token.role == 'staff' || request.auth.token.role == 'admin'); }
    function isTutor() { return isSignedIn() && (request.auth.token.role == 'tutor' || request.auth.token.role == 'admin'); }
    function isParent() { return isSignedIn() && (request.auth.token.role == 'parent' || request.auth.token.role == 'admin'); }
    function isKnownUser() { return isSignedIn() && (request.auth.token.role == 'admin' || request.auth.token.role == 'staff' || request.auth.token.role == 'tutor' || request.auth.token.role == 'parent'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailOwner(email) { return isSignedIn() && request.auth.token.email == email; }
    function isPublic() { return request.auth == null; }

    match /enrollments/{enrollmentId} {
      allow create: if true;
      allow read:   if isStaff() || isPublic() || isSignedIn();
      allow update: if isStaff() || isPublic() || isSignedIn();
      allow delete: if isStaff();
    }
    match /pending_students/{docId} {
      allow create: if true;
      allow read:   if isStaff() || isPublic();
      allow update: if isStaff();
      allow delete: if isStaff();
    }
    match /referral_transactions/{docId} {
      allow create: if true;
      allow read:   if isStaff() || isParent() || isPublic();
      allow update: if isStaff();
      allow delete: if isStaff();
    }
    match /students/{studentId} {
      allow read:   if isSignedIn();
      allow create: if isStaff() || isParent();
      allow update: if isStaff() || isParent();
      allow delete: if isStaff();
    }
    match /student_results/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /student_activity_log/{docId} {
      allow read:           if isSignedIn();
      allow create:         if isSignedIn();
      allow update, delete: if isStaff();
    }
    match /studentEvents/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /tutors/{tutorId} {
      allow read:   if isSignedIn();
      allow create: if isStaff();
      allow update: if isStaff() || isOwner(tutorId);
      allow delete: if isStaff();
    }
    match /tutor_saved_reports/{tutorEmail} {
      allow read, write: if isStaff() || isEmailOwner(tutorEmail);
    }
    match /tutor_submissions/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /tutor_messages/{docId} {
      allow read:   if isSignedIn();
      allow create: if isStaff() || isTutor();
      allow update: if isStaff();
      allow delete: if isStaff();
    }
    match /tutor_notifications/{docId} {
      allow read:   if isSignedIn();
      allow create: if isStaff();
      allow update: if isTutor() || isStaff();
      allow delete: if isStaff();
    }
    match /tutorAssignments/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isStaff();
      allow delete:         if isStaff();
    }
    match /homework_assignments/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /schedules/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /ttt_games/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor();
      allow delete:         if isStaff();
    }
    match /recall_requests/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isStaff();
    }
    match /tenure_bonus_logs/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isStaff();
      allow delete:         if isStaff();
    }
    match /daily_topics/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /gamification/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /leaderboard/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /parent_users/{parentId} {
      allow read:   if isSignedIn() || isPublic();
      allow create: if true;
      allow update: if isStaff() || isOwner(parentId) || isPublic();
      allow delete: if isStaff();
    }
    match /parent_messages/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isStaff();
    }
    match /parent_feedback/{docId} {
      allow read:           if isStaff();
      allow create:         if isSignedIn();
      allow update, delete: if isStaff();
    }
    match /email_reminders/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isStaff();
      allow delete:         if isStaff();
    }
    match /tests/{testId} {
      allow read:           if isSignedIn();
      allow create, update: if isTutor() || isStaff();
      allow delete:         if isStaff();
    }
    match /admin_questions/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isStaff();
      allow delete:         if isStaff();
    }
    match /staff/{staffId} {
      allow create: if true;
      allow read:   if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin() || isSignedIn();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }
    match /settings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /management_activity/{docId} {
      allow read:           if isStaff();
      allow create:         if isSignedIn();
      allow update, delete: if isStaff();
    }
    match /management_notifications/{docId} {
      allow read:           if isStaff();
      allow create:         if isSignedIn();
      allow update, delete: if isStaff();
    }
    match /system_logs/{docId} {
      allow read:           if isAdmin();
      allow create:         if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /conversations/{docId} {
      allow read, create, update: if isSignedIn();
      allow delete:               if isStaff();
    }
    match /{newCollection}/{docId} {
      allow read, write: if isAdmin();
    }
    match /{newCollection}/{docId}/{subCollection}/{subDocId} {
      allow read, write: if isAdmin();
    }
  }
}