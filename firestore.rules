rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // UPDATED RULES - ALLOW ENROLLMENT UPDATES
    // ============================================
    
    // 1. ENROLLMENT PORTAL: Allow public signup AND updates
    match /enrollments/{enrollmentId} {
      allow create: if true; // Anyone can create
      allow read: if true; // Anyone can read (for resume links)
      allow update: if true; // Allow updates for auto-save
      allow delete: if false; // Still prevent deletion
    }
    
    // 2. TUTOR SYSTEM: Keep working (your existing rule)
    match /tutor_saved_reports/{tutorEmail} {
      allow read, write: if 
        request.auth != null && 
        request.auth.token.email == tutorEmail;
    }
    
    // 3. ALL OTHER SITES: Allow everything
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
